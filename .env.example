# Copy this file to .env.local and fill in real values.
# Supabase uses the NEW API key system (publishable + secret), NOT the
# legacy anon/service_role JWT keys. See CLAUDE.md.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   # client-side, low-privilege, respects RLS
SUPABASE_SECRET_KEY=sb_secret_...                         # server-only, bypasses RLS — never expose to client

# Database (Drizzle connects directly via the Supabase transaction pooler)
DATABASE_URL=postgresql://postgres.your-project-ref:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Email (Phase 9). Without RESEND_API_KEY, sends degrade to in-app links.
RESEND_API_KEY=re_...
EMAIL_FROM=Volleyball <noreply@your-domain.com>

# Weekly-digest cron (Phase 9). Vercel sends `Authorization: Bearer $CRON_SECRET`
# to /api/cron/weekly-digest; set the same value here and in Vercel settings.
CRON_SECRET=generate-a-long-random-string

# AI features (added post-v0, Phase 12+)
ANTHROPIC_API_KEY=sk-ant-...
